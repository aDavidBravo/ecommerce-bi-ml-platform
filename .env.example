# ==========================================
# E-COMMERCE BI/ML PLATFORM - CONFIGURATION
# ==========================================

# ========================================== 
# DATABASE CONNECTIONS
# ==========================================

# PostgreSQL (Operational DB)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce_db
POSTGRES_USER=dataengineer
POSTGRES_PASSWORD=changeme
POSTGRES_CONN_STRING=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=ecommerce
MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGO_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/${MONGO_DB}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================== 
# DATA WAREHOUSE
# ==========================================

# Snowflake
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=ECOMMERCE_DWH
SNOWFLAKE_SCHEMA=DWH
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=DATA_ENGINEER

# Amazon Redshift
REDSHIFT_HOST=your-cluster.region.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=ecommerce_dwh
REDSHIFT_USER=admin
REDSHIFT_PASSWORD=your_password

# Google BigQuery
BIGQUERY_PROJECT_ID=your-project-id
BIGQUERY_DATASET=ecommerce_analytics
BIGQUERY_CREDENTIALS_PATH=./config/gcp-credentials.json

# Data Warehouse Connection (primary)
DWH_TYPE=snowflake  # Options: snowflake, redshift, bigquery
DWH_CONN_STRING=snowflake://${SNOWFLAKE_USER}:${SNOWFLAKE_PASSWORD}@${SNOWFLAKE_ACCOUNT}/${SNOWFLAKE_DATABASE}/${SNOWFLAKE_SCHEMA}?warehouse=${SNOWFLAKE_WAREHOUSE}&role=${SNOWFLAKE_ROLE}

# ========================================== 
# CLOUD STORAGE
# ==========================================

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=ecommerce-data-lake
AWS_S3_RAW_PREFIX=raw/
AWS_S3_PROCESSED_PREFIX=processed/
AWS_S3_CURATED_PREFIX=curated/

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT=your_storage_account
AZURE_STORAGE_KEY=your_storage_key
AZURE_CONTAINER_NAME=ecommerce-data

# Google Cloud Storage
GCS_BUCKET_NAME=ecommerce-data-lake
GCS_PROJECT_ID=your-project-id

# ========================================== 
# BIG DATA PROCESSING
# ==========================================

# Databricks
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_token
DATABRICKS_CLUSTER_ID=your_cluster_id
DATABRICKS_WORKSPACE_URL=https://your-workspace.cloud.databricks.com

# Spark Configuration
SPARK_MASTER=spark://spark-master:7077
SPARK_EXECUTOR_MEMORY=4g
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_CORES=2

# ========================================== 
# MLOPS & EXPERIMENT TRACKING
# ==========================================

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=ecommerce-ml-experiments
MLFLOW_ARTIFACT_LOCATION=s3://ecommerce-data/mlflow-artifacts/

# Weights & Biases
WANDB_API_KEY=your_wandb_api_key
WANDB_PROJECT=ecommerce-ml
WANDB_ENTITY=your_entity

# ========================================== 
# ML MODEL SERVING
# ==========================================

# AWS SageMaker
SAGEMAKER_EXECUTION_ROLE=arn:aws:iam::account:role/SageMakerRole
SAGEMAKER_BUCKET=ecommerce-sagemaker
SAGEMAKER_REGION=us-east-1

# Azure ML
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=ecommerce-ml-rg
AZURE_WORKSPACE_NAME=ecommerce-ml-workspace

# ========================================== 
# WORKFLOW ORCHESTRATION
# ==========================================

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__WEBSERVER__SECRET_KEY=your_secret_key_here
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__API__AUTH_BACKEND=airflow.api.auth.backend.basic_auth

# dbt
DBT_PROFILES_DIR=./config/dbt
DBT_TARGET=prod

# ========================================== 
# BUSINESS INTELLIGENCE
# ==========================================

# Power BI
POWERBI_CLIENT_ID=your_client_id
POWERBI_CLIENT_SECRET=your_client_secret
POWERBI_TENANT_ID=your_tenant_id
POWERBI_EXECUTIVE_DATASET_ID=dataset_id_1
POWERBI_SALES_DATASET_ID=dataset_id_2
POWERBI_CUSTOMER_DATASET_ID=dataset_id_3

# Tableau
TABLEAU_SERVER_URL=https://your-server.tableau.com
TABLEAU_SITE_ID=your_site
TABLEAU_TOKEN_NAME=your_token_name
TABLEAU_TOKEN_VALUE=your_token_value

# ========================================== 
# EXTERNAL APIS
# ==========================================

# Google Analytics
GA_PROPERTY_ID=your_property_id
GA_CREDENTIALS_PATH=./config/ga-credentials.json

# Stripe (Payment Data)
STRIPE_API_KEY=your_stripe_key

# Sendgrid (Email Analytics)
SENDGRID_API_KEY=your_sendgrid_key

# ========================================== 
# SECURITY & AUTH
# ==========================================

# JWT Secret
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Keys
API_KEY_SALT=your_salt
ENCRYPTION_KEY=your_encryption_key

# ========================================== 
# APPLICATION SETTINGS
# ==========================================

# Environment
ENVIRONMENT=production  # Options: development, staging, production
DEBUG=False
LOG_LEVEL=INFO

# Application
APP_NAME=E-Commerce BI/ML Platform
APP_VERSION=1.0.0
APP_PORT=8000

# Data Retention
DATA_RETENTION_DAYS=365
LOG_RETENTION_DAYS=90

# ========================================== 
# MONITORING & ALERTING
# ==========================================

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000

# Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_RECIPIENTS=data-team@company.com,executives@company.com

# Slack Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#data-alerts

# ========================================== 
# FEATURE FLAGS
# ==========================================

ENABLE_WEB_SCRAPING=true
ENABLE_REAL_TIME_PROCESSING=true
ENABLE_AUTO_ML=false
ENABLE_A_B_TESTING=true
ENABLE_PERSONALIZATION=true

# ========================================== 
# PERFORMANCE TUNING
# ==========================================

# Database Connection Pooling
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Cache Settings
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=1024

# Batch Processing
BATCH_SIZE=10000
MAX_WORKERS=4

# ========================================== 
# DEVELOPMENT TOOLS
# ==========================================

# Jupyter
JUPYTER_PORT=8888
JUPYTER_TOKEN=

# Streamlit
STREAMLIT_PORT=8501

# VS Code Server
VSCODE_PORT=8443
